{
  "info": {
    "name": "JetVina Realtime API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.minhtien.online" },
    { "key": "apiKey", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "conversationId", "value": "" },
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "List my conversations",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{apiKey}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/realtime/conversations"
      }
    },
    {
      "name": "Create booking support conversation",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-API-Key", "value": "{{apiKey}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"bookingId\": {{bookingId}}, \"subject\": \"Booking support\"}"
        },
        "url": "{{baseUrl}}/realtime/conversations"
      }
    },
    {
      "name": "List messages",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{apiKey}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/realtime/conversations/{{conversationId}}/messages"
      }
    },
    {
      "name": "Send message",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-API-Key", "value": "{{apiKey}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"content\": \"Hello JetVina support\"}"
        },
        "url": "{{baseUrl}}/realtime/conversations/{{conversationId}}/messages"
      }
    },
    {
      "name": "Mark conversation read",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "X-API-Key", "value": "{{apiKey}}" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/realtime/conversations/{{conversationId}}/read"
      }
    }
  ]
}

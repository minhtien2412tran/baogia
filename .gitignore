# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Next.js build output
.next/
out/

# NestJS build output
dist/
/apps/api/dist

# IDEs and editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Operating System files
.DS_Store
Thumbs.db

# Env files / secrets
.env
.env.*
!.env.example
!.env*.example
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
.env.bak*
*.env.bak*
*.pem
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
credentials.json
*service-account*.json
*.kubeconfig
.secrets/
/tmp/secrets/

# Generated OpenAPI client (regenerate: pnpm openapi:client)
/packages/api-client/src/generated/**
!/packages/api-client/src/generated/.gitkeep
/packages/api-client/openapi/openapi.json
/packages/api-client/openapi/openapi.yaml

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Prisma
/apps/api/prisma/*.db
/apps/api/prisma/*.db-journal

# Playwright reports
/playwright-report/
/test-results/

# Build artifacts
*.tsbuildinfo
.turbo/

# Ops / secrets (keep out of docs)
docs/DKIM_*.txt

# Cursor — ignore local IDE state; keep Spec Kit skills + project rules tracked
.cursor/*
!.cursor/rules/
!.cursor/rules/**
!.cursor/skills/
!.cursor/skills/**

# Local JetVina media mirrors (UNVERIFIED — regenerate via pnpm sync:jetvina-media)
/apps/web/public/assets/jetvina/mirror/**
!/apps/web/public/assets/jetvina/mirror/.gitkeep
!/apps/web/public/assets/jetvina/RIGHTS.md

# Dev server PID file
.jetbay-web-dev.pid

/tmp/
!/tmp/.gitkeep

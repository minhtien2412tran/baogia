# Copy to apps/api/.env and adjust values as needed

# PostgreSQL (docker-compose defaults, or local PostgreSQL install)
DATABASE_URL="postgresql://jta_user:jta_password@localhost:5432/jta_db?schema=public"

# Redis (via docker-compose)
REDIS_URL="redis://localhost:6379"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minio_admin"
MINIO_SECRET_KEY="minio_password"
MINIO_BUCKET="jta-uploads"

# Mailpit (SMTP + web UI http://localhost:8025)
SMTP_HOST="localhost"
SMTP_PORT=1025

JWT_SECRET="dev-jta-secret-change-in-production"

PORT=4000

# Copy to apps/api/.env and adjust values as needed

# PostgreSQL (docker-compose defaults, or local PostgreSQL install)
DATABASE_URL="postgresql://jta_user:jta_password@localhost:5432/jta_db?schema=public"

# Redis (via docker-compose)
REDIS_URL="redis://localhost:6379"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minio_admin"
MINIO_SECRET_KEY="minio_password"
MINIO_BUCKET="jta-uploads"

# Mailpit (SMTP + web UI http://localhost:8025)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_FROM="J-TA <noreply@j-ta.local>"

# Stripe (optional — leave empty to use internal payment stub)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# OAuth (API verifies tokens)
GOOGLE_CLIENT_ID=""
APPLE_CLIENT_ID=""

# SMS OTP (dev mode logs code to API console when unset)
SMS_API_URL=""
SMS_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
ESMS_API_KEY=""
ESMS_SECRET_KEY=""
ESMS_BRANDNAME=""

# OnePay Vietnam
ONEPAY_MERCHANT_ID=""
ONEPAY_ACCESS_CODE=""
ONEPAY_SECURE_SECRET=""
ONEPAY_URL="https://mtf.onepay.vn/paygate/vpcpay.op"

# 9Pay Vietnam
NINEPAY_MERCHANT_KEY=""
NINEPAY_SECRET_KEY=""
NINEPAY_ENDPOINT=""

API_PUBLIC_URL="http://127.0.0.1:4000"
PAYMENT_RETURN_URL="http://localhost:3000/en-us/account"

JWT_SECRET="dev-jta-secret-change-in-production"

PORT=4000

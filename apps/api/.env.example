# =============================================================================
# JETBAY API — environment template (safe to commit)
# Copy:  cp apps/api/.env.example apps/api/.env
# Or:    node scripts/generate-local-env.mjs   (random local secrets)
# Prod:  use scripts/deploy/jetbay-be/env.production.template + rotate-secrets.sh
# NEVER commit apps/api/.env or production secrets.
# =============================================================================

APP_NAME=JetBay
APP_ENV=development
APP_VERSION=1.0.0
HOST=127.0.0.1
PORT=4000
NODE_ENV=development

# PostgreSQL (docker-compose defaults)
DATABASE_URL="postgresql://jetbay_user:jetbay_password@127.0.0.1:5432/jetbay_db?schema=public"

# Redis
REDIS_URL="redis://127.0.0.1:6379/0"

# Auth — REQUIRED in production (openssl rand -hex 48)
# Local: prefer node scripts/generate-local-env.mjs over these placeholders
JWT_SECRET="REPLACE_WITH_openssl_rand_hex_48"
REFRESH_TOKEN_SECRET="REPLACE_WITH_openssl_rand_hex_48"
API_KEY="REPLACE_WITH_openssl_rand_hex_32"
PAYMENT_SECRET="REPLACE_WITH_openssl_rand_hex_32"

# CORS / public URLs
CORS_ORIGIN="http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001"
API_PUBLIC_URL="http://127.0.0.1:4000"
PAYMENT_RETURN_URL="http://localhost:3000/en-us/account"

# MinIO (optional — empty = local uploads fallback)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minio_admin"
MINIO_SECRET_KEY="minio_password"
MINIO_BUCKET="jetbay-uploads"

# Mailpit (dev) — http://localhost:8025
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="JetBay <noreply@jetbay.local>"
SMTP_ENQUIRY_TO="sales@jetbay.local"
UPLOAD_PATH="./uploads"

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OAuth
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# SMS OTP (dev logs code when unset)
SMS_API_URL=
SMS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ESMS_API_KEY=
ESMS_SECRET_KEY=
ESMS_BRANDNAME=

# OnePay / 9Pay Vietnam
ONEPAY_MERCHANT_ID=
ONEPAY_ACCESS_CODE=
ONEPAY_SECURE_SECRET=
ONEPAY_URL="https://mtf.onepay.vn/paygate/vpcpay.op"
NINEPAY_MERCHANT_KEY=
NINEPAY_SECRET_KEY=
NINEPAY_ENDPOINT=

# Electronic signature (DocuSign) — leave unset to use mock provider
# SIGNATURE_PROVIDER=mock | docusign
SIGNATURE_PROVIDER=mock
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY=
DOCUSIGN_BASE_URL="https://demo.docusign.net/restapi"
DOCUSIGN_WEBHOOK_HMAC_SECRET=

# Content sync / brand (SAFE_REFERENCE_MODE defaults)
CONTENT_SYNC_ENABLED=true
CONTENT_SYNC_PUBLISH_ENABLED=false
EXTERNAL_MEDIA_IMPORT_ENABLED=false
NEW_BRAND_CONTENT_ENABLED=false
# Staging only until rightsStatus is CLIENT_PROVIDED/OWNED/LICENSED — do not enable in production without approval
JETVINA_OFFICIAL_LOGO_ENABLED=false
JETBAY_CONTENT_CLEANUP_ENABLED=true

# Web FE media flags (also set in apps/web/.env.local — NEXT_PUBLIC_* is not a security boundary alone)
# NEXT_PUBLIC_PREFER_JETVINA_MEDIA=true
# JETVINA_MEDIA_REMOTE_REVIEW_ENABLED=true
# JETVINA_MEDIA_LOCAL_MIRROR_ENABLED=true
# JETVINA_MEDIA_PRODUCTION_ENABLED=false

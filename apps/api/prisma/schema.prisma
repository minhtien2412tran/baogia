datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- AUTH & USERS ---

model User {
  id                   Int                   @id @default(autoincrement())
  email                String                @unique
  passwordHash         String?
  firstName            String?
  lastName             String?
  phone                String?
  accountType          String                @default("INDIVIDUAL") // INDIVIDUAL, COMPANY
  role                 String                @default("USER") // USER, ADMIN, SALES, CONTRACT_APPROVER
  companyId            Int?
  status               String                @default("ACTIVE") // ACTIVE, SUSPENDED
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  
  company              Company?              @relation(fields: [companyId], references: [id])
  authProviders        UserAuthProvider[]
  consentLogs          ConsentLog[]
  savedSearches        SavedSearch[]
  quoteRequests        QuoteRequest[]
  bookings             Booking[]
  jetCardAccounts      JetCardAccount[]
  travelCredits        TravelCreditLedger[]
  partnerApplications  PartnerApplication[]
  partnerAccounts      PartnerAccount[]
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]
  permissionOverrides  UserPermissionOverride[]
  airportScopes        UserAirportScope[]
  aircraftLocationUpdates AircraftLocationHistory[] @relation("LocationUpdatedBy")
  pricingEstimates     PricingEstimate[]     @relation("EstimateCreatedBy")
  contractsCreated     OperatorContract[]    @relation("ContractCreatedBy")
  contractsApproved    OperatorContract[]    @relation("ContractApprovedBy")
}

model UserAuthProvider {
  id              Int      @id @default(autoincrement())
  userId          Int
  provider        String   // GOOGLE, APPLE
  providerSubject String   @unique
  email           String?
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id              Int                   @id @default(autoincrement())
  legalName       String
  billingEmail    String
  taxCountry      String
  status          String                @default("ACTIVE")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  
  users           User[]
  authorizedUsers CompanyAuthorizedUser[]
  travelCredits   TravelCreditLedger[]
  partnerAccounts PartnerAccount[]
  bookings        Booking[]
}

model CompanyAuthorizedUser {
  id            Int      @id @default(autoincrement())
  companyId     Int
  userId        Int
  permissionSet String   @default("READ") // READ, WRITE, ADMIN
  createdAt     DateTime @default(now())
  
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// --- QUOTES & BOOKINGS ---

model QuoteRequest {
  id                Int                  @id @default(autoincrement())
  userId            Int?
  email             String
  phone             String
  firstName         String
  lastName          String
  tripType          String               @default("ONE_WAY") // ONE_WAY, ROUND_TRIP, MULTI_CITY
  sourcePage        String?
  status            String               @default("PENDING") // PENDING, OFFERED, EXPIRED, CONVERTED, CANCELLED
  locale            String               @default("en")
  currency          String               @default("USD")
  message           String?
  isConsentAccepted Boolean              @default(false)
  createdAt         DateTime             @default(now())
  
  user              User?                @relation(fields: [userId], references: [id])
  legs              QuoteLeg[]
  offers            QuoteOffer[]
  bookings          Booking[]
  worldCupItinerary WorldCupItinerary?
}

model QuoteLeg {
  id                 Int          @id @default(autoincrement())
  quoteRequestId     Int
  seq                Int          @default(0)
  fromAirportId      Int
  toAirportId        Int
  departureLocalAt   DateTime
  passengers         Int          @default(1)
  relatedMatchId     Int?
  
  quoteRequest       QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  fromAirport        Airport      @relation("LegFromAirport", fields: [fromAirportId], references: [id])
  toAirport          Airport      @relation("LegToAirport", fields: [toAirportId], references: [id])
  relatedMatch       WorldCupMatch? @relation(fields: [relatedMatchId], references: [id])
}

model QuoteOffer {
  id               Int          @id @default(autoincrement())
  quoteRequestId   Int
  aircraftModelId  Int
  operatorId       Int
  price            Decimal      @db.Decimal(12, 2)
  pricingBreakdown Json?
  expiresAt        DateTime
  status           String       @default("ACTIVE") // ACTIVE, EXPIRED, ACCEPTED
  createdAt        DateTime     @default(now())
  
  quoteRequest     QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  aircraftModel    AircraftModel @relation(fields: [aircraftModelId], references: [id])
  operator         Operator     @relation(fields: [operatorId], references: [id])
  bookings         Booking[]
}

model Booking {
  id                    Int                @id @default(autoincrement())
  quoteOfferId          Int?
  quoteRequestId        Int?
  userId                Int
  companyId             Int?
  aircraftId            Int?
  bookingCode           String?            @unique
  bookingType           String             @default("CHARTER") // CHARTER, FIXED_PRICE, EMPTY_LEG
  agreementStatus       String             @default("PENDING") // PENDING, SIGNED, BYPASSED
  bookingStatus         String             @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  customerRouteSummary  String?            // e.g. HAN → SGN (customer-facing)
  estimatedPriceTotal   Decimal?           @db.Decimal(12, 2)
  estimatedPriceCurrency String?           @default("USD")
  cancelReason          String?
  cancelNote            String?
  cancellationFee       Decimal?           @db.Decimal(12, 2)
  cancelledAt           DateTime?
  cancelledByUserId     Int?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  
  quoteOffer      QuoteOffer?        @relation(fields: [quoteOfferId], references: [id])
  quoteRequest    QuoteRequest?      @relation(fields: [quoteRequestId], references: [id])
  user            User               @relation(fields: [userId], references: [id])
  company         Company?           @relation(fields: [companyId], references: [id])
  aircraft        Aircraft?          @relation(fields: [aircraftId], references: [id])
  passengers      BookingPassenger[]
  payments        Payment[]
  documents       Document[]
  travelCredits   TravelCreditLedger[]
  jetCardTxns     JetCardTransaction[]
  flightLegs      BookingFlightLeg[]
  pricingEstimates PricingEstimate[]
  operatorContracts OperatorContract[]
}

model BookingPassenger {
  id             Int      @id @default(autoincrement())
  bookingId      Int
  firstName      String
  lastName       String
  passportNumber String?
  dateOfBirth    DateTime?
  nationality    String?
  
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Payment {
  id             Int      @id @default(autoincrement())
  bookingId      Int
  method         String   // BANK_TRANSFER, CREDIT_CARD, HOLD
  amount         Decimal  @db.Decimal(12, 2)
  currency       String   @default("USD")
  status         String   @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  transactionRef String?
  createdAt      DateTime @default(now())
  
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Document {
  id            Int      @id @default(autoincrement())
  bookingId     Int
  documentType  String   // CHARTER_AGREEMENT, TERM_AND_CONDITION
  policyVersion String
  signedAt      DateTime?
  signerId      Int?
  fileUrl       String
  status        String   @default("PENDING") // PENDING, SIGNED, EXPIRED
  createdAt     DateTime @default(now())
  
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// --- AIRCRAFT & AIRPORTS ---

model Airport {
  id                  Int                  @id @default(autoincrement())
  iata                String               @unique
  icao                String
  name                String
  city                String
  country             String               // display name (backward compatible)
  countryCode         String?              // ISO 3166-1 alpha-2
  countryName         String?
  continentCode       String?              // AF, AS, EU, NA, SA, OC, AN
  continentName       String?
  timezone            String
  latitude            Decimal?             @db.Decimal(10, 7)
  longitude           Decimal?             @db.Decimal(10, 7)
  status              String               @default("ACTIVE")
  canParkAircraft     Boolean              @default(true)
  landingFee          Decimal?             @db.Decimal(12, 2)
  parkingFee          Decimal?             @db.Decimal(12, 2)
  overnightFee        Decimal?             @db.Decimal(12, 2)
  handlingFee         Decimal?             @db.Decimal(12, 2)
  feeCurrency         String?              @default("USD")
  feeUpdatedAt        DateTime?
  operationalNotes    String?
  
  legsFrom            QuoteLeg[]           @relation("LegFromAirport")
  legsTo              QuoteLeg[]           @relation("LegToAirport")
  fixedRoutesFrom     FixedPriceRoute[]    @relation("RouteFromAirport")
  fixedRoutesTo       FixedPriceRoute[]    @relation("RouteToAirport")
  emptyLegsFrom       EmptyLegOffer[]      @relation("EmptyFromAirport")
  emptyLegsTo         EmptyLegOffer[]      @relation("EmptyToAirport")
  aircraftBased       Aircraft[]           @relation("AircraftBaseAirport")
  aircraftCurrent     Aircraft[]           @relation("AircraftCurrentAirport")
  locationHistoryFrom AircraftLocationHistory[] @relation("LocationFromAirport")
  locationHistoryTo   AircraftLocationHistory[] @relation("LocationToAirport")
  flightLegsFrom      BookingFlightLeg[]   @relation("FlightLegFrom")
  flightLegsTo        BookingFlightLeg[]   @relation("FlightLegTo")
  airportScopes       UserAirportScope[]

  @@index([continentCode])
  @@index([countryCode])
  @@index([status])
}

model AircraftCategory {
  id            Int             @id @default(autoincrement())
  code          String          @unique // LIGHT, MIDSIZE, HEAVY, etc.
  label         String
  maxPassengers Int             @default(8)
  
  models        AircraftModel[]
  fixedOptions  FixedPriceOption[]
}

model AircraftModel {
  id             Int              @id @default(autoincrement())
  manufacturer   String
  model          String
  categoryId     Int
  rangeKm        Int?
  speedKmh       Int?
  sleepCapacity  Int?
  cabinWidth     Decimal?         @db.Decimal(4, 2)
  cabinHeight    Decimal?         @db.Decimal(4, 2)
  cabinLength    Decimal?         @db.Decimal(4, 2)
  
  category       AircraftCategory @relation(fields: [categoryId], references: [id])
  quoteOffers    QuoteOffer[]
  emptyLegs      EmptyLegOffer[]
  aircraft       Aircraft[]
}

model Operator {
  id                 Int          @id @default(autoincrement())
  name               String
  legalName          String?
  registrationNumber String?
  region             String
  country            String?
  address            String?
  contactName        String?
  contactEmail       String?
  contactPhone       String?
  paymentTerms       String?
  cancellationPolicy String?
  complianceProfile  Json?
  status             String       @default("ACTIVE")
  
  quoteOffers        QuoteOffer[]
  aircraft           Aircraft[]
  contracts          OperatorContract[]
  contractTemplates  ContractTemplate[]
}

/// Tail-number aircraft instance (distinct from AircraftModel type catalog)
model Aircraft {
  id                   Int       @id @default(autoincrement())
  registration         String    @unique
  aircraftModelId      Int
  operatorId           Int
  baseAirportId        Int?
  currentAirportId     Int?
  availabilityStatus   String    @default("AVAILABLE") // AVAILABLE, ON_HOLD, BOOKED, IN_FLIGHT, MAINTENANCE, UNAVAILABLE, INACTIVE
  operationalStatus    String    @default("ACTIVE")
  availableFrom        DateTime?
  hourlyRate           Decimal?  @db.Decimal(12, 2)
  hourlyRateCurrency   String    @default("USD")
  minimumBillableHours Decimal   @default(1.0) @db.Decimal(4, 2)
  locationUpdatedAt    DateTime?
  locationUpdatedById  Int?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  aircraftModel        AircraftModel @relation(fields: [aircraftModelId], references: [id])
  operator             Operator      @relation(fields: [operatorId], references: [id])
  baseAirport          Airport?      @relation("AircraftBaseAirport", fields: [baseAirportId], references: [id])
  currentAirport       Airport?      @relation("AircraftCurrentAirport", fields: [currentAirportId], references: [id])
  locationHistory      AircraftLocationHistory[]
  flightLegs           BookingFlightLeg[]
  bookings             Booking[]
  pricingEstimates     PricingEstimate[]
  contracts            OperatorContract[]

  @@index([currentAirportId])
  @@index([availabilityStatus])
  @@index([operatorId])
}

model AircraftLocationHistory {
  id              Int      @id @default(autoincrement())
  aircraftId      Int
  fromAirportId   Int?
  toAirportId     Int
  changedAt       DateTime @default(now())
  reason          String?
  updatedByUserId Int?
  metadata        Json?

  aircraft        Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  fromAirport     Airport? @relation("LocationFromAirport", fields: [fromAirportId], references: [id])
  toAirport       Airport  @relation("LocationToAirport", fields: [toAirportId], references: [id])
  updatedBy       User?    @relation("LocationUpdatedBy", fields: [updatedByUserId], references: [id])

  @@index([aircraftId, changedAt])
}

model BookingFlightLeg {
  id                     Int      @id @default(autoincrement())
  bookingId              Int
  aircraftId             Int?
  fromAirportId          Int
  toAirportId            Int
  legType                String   // POSITIONING, PASSENGER, RETURN, REPOSITIONING, EMPTY_LEG
  sequence               Int      @default(0)
  departureAt            DateTime?
  arrivalAt              DateTime?
  estimatedFlightMinutes Int?
  estimatedDistanceKm    Decimal? @db.Decimal(10, 2)
  hasPassengers          Boolean  @default(false)
  passengerCount         Int      @default(0)
  hourlyRateSnapshot     Decimal? @db.Decimal(12, 2)
  currency               String   @default("USD")
  estimatedBaseCost      Decimal? @db.Decimal(12, 2)
  airportFees            Decimal? @db.Decimal(12, 2)
  handlingFees           Decimal? @db.Decimal(12, 2)
  parkingFees            Decimal? @db.Decimal(12, 2)
  crewFees               Decimal? @db.Decimal(12, 2)
  otherFees              Decimal? @db.Decimal(12, 2)
  estimatedTotalCost     Decimal? @db.Decimal(12, 2)
  status                 String   @default("PLANNED")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  booking                Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  aircraft               Aircraft? @relation(fields: [aircraftId], references: [id])
  fromAirport            Airport  @relation("FlightLegFrom", fields: [fromAirportId], references: [id])
  toAirport              Airport  @relation("FlightLegTo", fields: [toAirportId], references: [id])

  @@index([bookingId, sequence])
}

model PricingEstimate {
  id                Int      @id @default(autoincrement())
  bookingId         Int?
  quoteRequestId    Int?
  aircraftId        Int
  currency          String   @default("USD")
  billableHours     Decimal  @db.Decimal(8, 2)
  hourlyRateSnapshot Decimal @db.Decimal(12, 2)
  flightHourCost    Decimal  @db.Decimal(12, 2)
  airportFeesTotal  Decimal  @default(0) @db.Decimal(12, 2)
  handlingFeesTotal Decimal  @default(0) @db.Decimal(12, 2)
  parkingFeesTotal  Decimal  @default(0) @db.Decimal(12, 2)
  crewFeesTotal     Decimal  @default(0) @db.Decimal(12, 2)
  otherFeesTotal    Decimal  @default(0) @db.Decimal(12, 2)
  taxesTotal        Decimal  @default(0) @db.Decimal(12, 2)
  markupTotal       Decimal  @default(0) @db.Decimal(12, 2)
  estimatedTotal    Decimal  @db.Decimal(12, 2)
  formulaVersion    String   @default("v1")
  snapshot          Json     // immutable breakdown + legs + rates
  createdByUserId   Int?
  createdAt         DateTime @default(now())

  booking           Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  aircraft          Aircraft @relation(fields: [aircraftId], references: [id])
  createdBy         User?    @relation("EstimateCreatedBy", fields: [createdByUserId], references: [id])

  @@index([bookingId])
  @@index([aircraftId])
}

// --- COMMERCIAL PROGRAMS ---

model FixedPriceRoute {
  id            Int                @id @default(autoincrement())
  slug          String             @unique
  fromAirportId Int
  toAirportId   Int
  region        String
  status        String             @default("ACTIVE")
  createdAt     DateTime           @default(now())
  
  fromAirport   Airport            @relation("RouteFromAirport", fields: [fromAirportId], references: [id])
  toAirport     Airport            @relation("RouteToAirport", fields: [toAirportId], references: [id])
  options       FixedPriceOption[]
}

model FixedPriceOption {
  id            Int              @id @default(autoincrement())
  routeId       Int
  categoryId    Int
  price         Decimal          @db.Decimal(12, 2)
  paxLimit      Int              @default(8)
  includedTerms String?
  
  route         FixedPriceRoute  @relation(fields: [routeId], references: [id], onDelete: Cascade)
  category      AircraftCategory @relation(fields: [categoryId], references: [id])
}

model EmptyLegOffer {
  id              Int           @id @default(autoincrement())
  slug            String        @unique
  fromAirportId   Int
  toAirportId     Int
  departAt        DateTime
  aircraftModelId Int
  price           Decimal       @db.Decimal(12, 2)
  status          String        @default("ACTIVE") // ACTIVE, EXPIRED, BOOKED
  discountPct     Int           @default(0)
  createdAt       DateTime      @default(now())
  
  fromAirport     Airport       @relation("EmptyFromAirport", fields: [fromAirportId], references: [id])
  toAirport       Airport       @relation("EmptyToAirport", fields: [toAirportId], references: [id])
  aircraftModel   AircraftModel @relation(fields: [aircraftModelId], references: [id])
}

model JetCardPlan {
  id            Int              @id @default(autoincrement())
  name          String
  hours         Int
  validityYears Int              @default(2)
  minNoticeHours Int             @default(24)
  dailyMinHours Decimal          @db.Decimal(3, 1)
  price         Decimal          @db.Decimal(12, 2)
  
  accounts      JetCardAccount[]
}

model JetCardAccount {
  id             Int                  @id @default(autoincrement())
  userId         Int
  planId         Int
  purchasedAt    DateTime             @default(now())
  expiresAt      DateTime
  remainingHours Decimal              @db.Decimal(6, 2)
  
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           JetCardPlan          @relation(fields: [planId], references: [id])
  transactions   JetCardTransaction[]
}

model JetCardTransaction {
  id               Int            @id @default(autoincrement())
  jetCardAccountId Int
  txnType          String         // DEDUCTION, TOP_UP, FEE
  hoursDelta       Decimal        @db.Decimal(6, 2)
  bookingId        Int?
  note             String?
  createdAt        DateTime       @default(now())
  
  jetCardAccount   JetCardAccount @relation(fields: [jetCardAccountId], references: [id], onDelete: Cascade)
  booking          Booking?       @relation(fields: [bookingId], references: [id])
}

model TravelCreditPackage {
  id             Int      @id @default(autoincrement())
  name           String
  creditAmount   Decimal  @db.Decimal(12, 2)
  priceUsd       Decimal  @db.Decimal(12, 2)
  bonusPct       Decimal? @db.Decimal(5, 2)
  validityMonths Int      @default(12)
  currency       String   @default("USD")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TravelCreditLedger {
  id           Int      @id @default(autoincrement())
  userId       Int?
  companyId    Int?
  bookingId    Int?
  creditsDelta Decimal  @db.Decimal(12, 2)
  expiresAt    DateTime
  reason       String
  createdAt    DateTime @default(now())
  
  user         User?    @relation(fields: [userId], references: [id])
  company      Company? @relation(fields: [companyId], references: [id])
  booking      Booking? @relation(fields: [bookingId], references: [id])
}

// --- PARTNERS ---

model PartnerProgram {
  id           Int                  @id @default(autoincrement())
  code         String               @unique // SERVICE, REFERRAL, OFFICIAL
  name         String
  benefits     Json?
  
  applications PartnerApplication[]
  accounts     PartnerAccount[]
}

model PartnerApplication {
  id           Int            @id @default(autoincrement())
  userId       Int
  programId    Int
  whatsapp     String?
  wechat       String?
  reviewStatus String         @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedAt   DateTime?
  createdAt    DateTime       @default(now())
  
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  program      PartnerProgram @relation(fields: [programId], references: [id])
}

model PartnerAccount {
  id                   Int            @id @default(autoincrement())
  userId               Int
  companyId            Int?
  programId            Int
  dashboardPermissions String         @default("BASIC")
  createdAt            DateTime       @default(now())
  
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  company              Company?       @relation(fields: [companyId], references: [id])
  program              PartnerProgram @relation(fields: [programId], references: [id])
}

// --- CONTENT MANAGEMENT (CMS) ---

model ContentCategory {
  id       Int              @id @default(autoincrement())
  name     String
  slug     String           @unique
  articles ContentArticle[]
}

model ContentArticle {
  id           Int              @id @default(autoincrement())
  type         String           // NEWS, BLOG, LEGAL, PAGE
  slug         String           @unique
  categoryId   Int?
  author       String?
  thumbnail    String?
  isPublished  Boolean          @default(false)
  shareEnabled Boolean          @default(true)
  publishedAt  DateTime?
  createdAt    DateTime         @default(now())
  
  category     ContentCategory? @relation(fields: [categoryId], references: [id])
}

model ContentTranslation {
  id             Int     @id @default(autoincrement())
  entityType     String  // ARTICLE, VIDEO, PLAN, DESTINATION
  entityId       Int
  locale         String
  title          String
  body           String
  excerpt        String?
  seoTitle       String?
  seoDescription String?
  
  @@unique([entityType, entityId, locale])
}

model Video {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  videoUrl    String
  thumbnail   String?
  duration    Int       @default(0) // in seconds
  viewCount   Int       @default(0)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
}

model Destination {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  category    String    // ISLAND, SKI, GOLF
  city        String
  country     String
  thumbnail   String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --- CAMPAIGNS ---

model WorldCupMatch {
  id        Int        @id @default(autoincrement())
  matchDate DateTime
  stage     String
  homeTeam  String
  awayTeam  String
  hostCity  String
  stadium   String
  
  legs      QuoteLeg[]
}

model WorldCupItinerary {
  id             Int          @id @default(autoincrement())
  quoteRequestId Int          @unique
  campaignCode   String
  
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
}

// --- LOGS & MISC ---

model SavedSearch {
  id           Int      @id @default(autoincrement())
  userId       Int
  queryPayload Json
  locale       String   @default("en")
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConsentLog {
  id            Int      @id @default(autoincrement())
  userId        Int
  subject       String   // COOKIE_ANALYTICS, PRIVACY_POLICY, TERMS
  policyVersion String
  acceptedAt    DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String
  entityType String?
  entityId   String?
  beforeData Json?
  afterData  Json?
  metadata   Json?
  details    Json?    // legacy free-form (backward compatible)
  ipAddress  String?
  sessionId  String?
  createdAt  DateTime @default(now())
  
  user       User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([action, createdAt])
}

model OtpCode {
  id        Int       @id @default(autoincrement())
  phone     String
  code      String
  purpose   String    // LOGIN, REGISTER
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone, purpose])
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// --- CUSTOMER CARE EMAIL ---

model EmailSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  userId    Int?
  locale    String   @default("en")
  source    String   @default("NEWSLETTER")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

model EmailCampaignLog {
  id          Int       @id @default(autoincrement())
  email       String
  userId      Int?
  campaignKey String
  referenceId String    @default("")
  locale      String    @default("en")
  status      String    @default("PENDING")
  scheduledAt DateTime  @default(now())
  sentAt      DateTime?
  error       String?
  meta        Json?
  createdAt   DateTime  @default(now())

  @@unique([campaignKey, email, referenceId])
  @@index([status, scheduledAt])
  @@index([email])
}

// --- RBAC / PERMISSIONS ---

model RolePermission {
  id         Int      @id @default(autoincrement())
  role       String   // ADMIN, SALES, CONTRACT_APPROVER, USER
  permission String
  createdAt  DateTime @default(now())

  @@unique([role, permission])
  @@index([role])
}

model UserPermissionOverride {
  id         Int      @id @default(autoincrement())
  userId     Int
  permission String
  effect     String   // INHERIT, ALLOW, DENY
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  updatedBy  Int?

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@index([userId])
}

model UserAirportScope {
  id            Int      @id @default(autoincrement())
  userId        Int
  scopeType     String   // ALL, CONTINENT, COUNTRY, SELECTED_AIRPORTS, NONE
  continentCode String?
  countryCode   String?
  airportId     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     Int?
  updatedBy     Int?

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  airport       Airport? @relation(fields: [airportId], references: [id])

  @@index([userId])
  @@index([scopeType])
}

// --- CONTRACTS ---

model ContractTemplate {
  id            Int      @id @default(autoincrement())
  name          String
  operatorId    Int?
  aircraftCategoryCode String?
  language      String   @default("en")
  version       Int      @default(1)
  effectiveFrom DateTime @default(now())
  fileUrl       String?
  placeholders  Json?
  status        String   @default("ACTIVE") // ACTIVE, ARCHIVED
  createdBy     Int?
  approvedBy    Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  operator      Operator? @relation(fields: [operatorId], references: [id])
  contracts     OperatorContract[]

  @@index([status])
}

model OperatorContract {
  id                   Int       @id @default(autoincrement())
  bookingId            Int
  aircraftId           Int
  operatorId           Int
  contractTemplateId   Int?
  contractNumber       String?
  version              Int       @default(1)
  status               String    @default("DRAFT")
  // DRAFT, PENDING_APPROVAL, CHANGES_REQUESTED, APPROVED, REJECTED,
  // SENT_FOR_SIGNATURE, PARTIALLY_SIGNED, COMPLETED, DECLINED, VOIDED, EXPIRED, SUPERSEDED, CANCELLED
  amount               Decimal?  @db.Decimal(12, 2)
  currency             String    @default("USD")
  documentPath         String?
  createdByUserId      Int?
  submittedByUserId    Int?
  approvedByUserId     Int?
  approvedAt           DateTime?
  rejectedByUserId     Int?
  rejectedAt           DateTime?
  rejectionReason      String?
  docusignEnvelopeId   String?
  sentAt               DateTime?
  completedAt          DateTime?
  voidedAt             DateTime?
  supersededContractId Int?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  booking              Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  aircraft             Aircraft  @relation(fields: [aircraftId], references: [id])
  operator             Operator  @relation(fields: [operatorId], references: [id])
  contractTemplate     ContractTemplate? @relation(fields: [contractTemplateId], references: [id])
  createdBy            User?     @relation("ContractCreatedBy", fields: [createdByUserId], references: [id])
  approvedBy           User?     @relation("ContractApprovedBy", fields: [approvedByUserId], references: [id])
  history              ContractApprovalHistory[]
  signatureEvents      SignatureWebhookEvent[]

  @@index([bookingId])
  @@index([status])
  @@index([docusignEnvelopeId])
  @@index([aircraftId])
}

model ContractApprovalHistory {
  id          Int      @id @default(autoincrement())
  contractId  Int
  action      String   // SUBMIT, APPROVE, REJECT, REQUEST_CHANGES, VOID, SEND, COMPLETE
  actorUserId Int?
  note        String?
  beforeStatus String?
  afterStatus  String?
  createdAt   DateTime @default(now())

  contract    OperatorContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, createdAt])
}

model SignatureWebhookEvent {
  id          Int      @id @default(autoincrement())
  eventId     String   @unique
  provider    String   @default("MOCK") // MOCK, DOCUSIGN
  contractId  Int?
  envelopeId  String?
  eventType   String
  payload     Json?
  processedAt DateTime?
  createdAt   DateTime @default(now())

  contract    OperatorContract? @relation(fields: [contractId], references: [id])

  @@index([envelopeId])
}

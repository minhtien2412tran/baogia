datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- AUTH & USERS ---

model User {
  id                   Int                   @id @default(autoincrement())
  email                String                @unique
  passwordHash         String?
  firstName            String?
  lastName             String?
  phone                String?
  accountType          String                @default("INDIVIDUAL") // INDIVIDUAL, COMPANY
  role                 String                @default("USER") // USER, ADMIN
  companyId            Int?
  status               String                @default("ACTIVE") // ACTIVE, SUSPENDED
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  
  company              Company?              @relation(fields: [companyId], references: [id])
  authProviders        UserAuthProvider[]
  consentLogs          ConsentLog[]
  savedSearches        SavedSearch[]
  quoteRequests        QuoteRequest[]
  bookings             Booking[]
  jetCardAccounts      JetCardAccount[]
  travelCredits        TravelCreditLedger[]
  partnerApplications  PartnerApplication[]
  partnerAccounts      PartnerAccount[]
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]
  permissionOverrides  UserPermissionOverride[]
  airportScope         UserAirportScope?
  contractsCreated     OperatorContract[]      @relation("ContractCreatedBy")
  contractsApproved    OperatorContract[]      @relation("ContractApprovedBy")
}

model UserAuthProvider {
  id              Int      @id @default(autoincrement())
  userId          Int
  provider        String   // GOOGLE, APPLE
  providerSubject String   @unique
  email           String?
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id              Int                   @id @default(autoincrement())
  legalName       String
  billingEmail    String
  taxCountry      String
  status          String                @default("ACTIVE")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  
  users           User[]
  authorizedUsers CompanyAuthorizedUser[]
  travelCredits   TravelCreditLedger[]
  partnerAccounts PartnerAccount[]
  bookings        Booking[]
}

model CompanyAuthorizedUser {
  id            Int      @id @default(autoincrement())
  companyId     Int
  userId        Int
  permissionSet String   @default("READ") // READ, WRITE, ADMIN
  createdAt     DateTime @default(now())
  
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// --- QUOTES & BOOKINGS ---

model QuoteRequest {
  id                Int                  @id @default(autoincrement())
  userId            Int?
  email             String
  phone             String
  firstName         String
  lastName          String
  tripType          String               @default("ONE_WAY") // ONE_WAY, ROUND_TRIP, MULTI_CITY
  sourcePage        String?
  status            String               @default("PENDING") // PENDING, OFFERED, EXPIRED, CONVERTED, CANCELLED
  locale            String               @default("en")
  currency          String               @default("USD")
  message           String?
  isConsentAccepted Boolean              @default(false)
  createdAt         DateTime             @default(now())
  
  user              User?                @relation(fields: [userId], references: [id])
  legs              QuoteLeg[]
  offers            QuoteOffer[]
  bookings          Booking[]
  flightLegs        FlightLeg[]
  worldCupItinerary WorldCupItinerary?
}

model QuoteLeg {
  id                 Int          @id @default(autoincrement())
  quoteRequestId     Int
  seq                Int          @default(0)
  fromAirportId      Int
  toAirportId        Int
  departureLocalAt   DateTime
  passengers         Int          @default(1)
  relatedMatchId     Int?
  
  quoteRequest       QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  fromAirport        Airport      @relation("LegFromAirport", fields: [fromAirportId], references: [id])
  toAirport          Airport      @relation("LegToAirport", fields: [toAirportId], references: [id])
  relatedMatch       WorldCupMatch? @relation(fields: [relatedMatchId], references: [id])
}

model QuoteOffer {
  id               Int          @id @default(autoincrement())
  quoteRequestId   Int
  aircraftModelId  Int
  operatorId       Int
  price            Decimal      @db.Decimal(12, 2)
  pricingBreakdown Json?
  expiresAt        DateTime
  status           String       @default("ACTIVE") // ACTIVE, EXPIRED, ACCEPTED
  createdAt        DateTime     @default(now())
  
  quoteRequest     QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  aircraftModel    AircraftModel @relation(fields: [aircraftModelId], references: [id])
  operator         Operator     @relation(fields: [operatorId], references: [id])
  bookings         Booking[]
}

model Booking {
  id                 Int                @id @default(autoincrement())
  quoteOfferId       Int?
  quoteRequestId     Int?
  userId             Int
  companyId          Int?
  bookingType        String             @default("CHARTER") // CHARTER, FIXED_PRICE, EMPTY_LEG
  agreementStatus    String             @default("PENDING") // PENDING, SIGNED, BYPASSED
  bookingStatus      String             @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  estimatedCost      Decimal?           @db.Decimal(12, 2)
  estimatedPrice     Decimal?           @db.Decimal(12, 2)
  currency           String?            @default("USD")
  selectedAircraftId Int?
  pricingStatus      String?            // ESTIMATED, CONFIRMED, SUPERSEDED
  contractStatus     String?            // NONE, DRAFT, PENDING_APPROVAL, APPROVED, SENT, COMPLETED
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  
  quoteOffer         QuoteOffer?        @relation(fields: [quoteOfferId], references: [id])
  quoteRequest       QuoteRequest?      @relation(fields: [quoteRequestId], references: [id])
  user               User               @relation(fields: [userId], references: [id])
  company            Company?           @relation(fields: [companyId], references: [id])
  selectedAircraft   Aircraft?          @relation(fields: [selectedAircraftId], references: [id])
  passengers         BookingPassenger[]
  payments           Payment[]
  documents          Document[]
  travelCredits      TravelCreditLedger[]
  jetCardTxns        JetCardTransaction[]
  flightLegs         FlightLeg[]
  operatorContracts  OperatorContract[]
}

model BookingPassenger {
  id             Int      @id @default(autoincrement())
  bookingId      Int
  firstName      String
  lastName       String
  passportNumber String?
  dateOfBirth    DateTime?
  nationality    String?
  
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Payment {
  id             Int      @id @default(autoincrement())
  bookingId      Int
  method         String   // BANK_TRANSFER, CREDIT_CARD, HOLD
  amount         Decimal  @db.Decimal(12, 2)
  currency       String   @default("USD")
  status         String   @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  transactionRef String?
  createdAt      DateTime @default(now())
  
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Document {
  id            Int      @id @default(autoincrement())
  bookingId     Int
  documentType  String   // CHARTER_AGREEMENT, TERM_AND_CONDITION
  policyVersion String
  signedAt      DateTime?
  signerId      Int?
  fileUrl       String
  status        String   @default("PENDING") // PENDING, SIGNED, EXPIRED
  createdAt     DateTime @default(now())
  
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// --- AIRCRAFT & AIRPORTS ---

model Airport {
  id                  Int                  @id @default(autoincrement())
  iata                String               @unique
  icao                String
  name                String
  city                String
  country             String
  countryCode         String?              // ISO 3166-1 alpha-2
  continentCode       String?              // AS EU NA SA AF OC
  timezone            String
  latitude            Decimal?             @db.Decimal(10, 7)
  longitude           Decimal?             @db.Decimal(10, 7)
  status              String               @default("ACTIVE")
  canParkAircraft     Boolean              @default(true)
  landingFee          Decimal?             @db.Decimal(12, 2)
  parkingFee          Decimal?             @db.Decimal(12, 2)
  overnightFee        Decimal?             @db.Decimal(12, 2)
  handlingFee         Decimal?             @db.Decimal(12, 2)
  feeCurrency         String?              @default("USD")
  feeUpdatedAt        DateTime?
  opsNotes            String?
  
  legsFrom            QuoteLeg[]           @relation("LegFromAirport")
  legsTo              QuoteLeg[]           @relation("LegToAirport")
  fixedRoutesFrom     FixedPriceRoute[]    @relation("RouteFromAirport")
  fixedRoutesTo       FixedPriceRoute[]    @relation("RouteToAirport")
  emptyLegsFrom       EmptyLegOffer[]      @relation("EmptyFromAirport")
  emptyLegsTo         EmptyLegOffer[]      @relation("EmptyToAirport")
  fleetBasedHere      Aircraft[]           @relation("AircraftBaseAirport")
  fleetCurrentlyHere  Aircraft[]           @relation("AircraftCurrentAirport")
  locationHistoryFrom AircraftLocationHistory[] @relation("LocHistFrom")
  locationHistoryTo   AircraftLocationHistory[] @relation("LocHistTo")
  flightLegsFrom      FlightLeg[]          @relation("FlightLegFrom")
  flightLegsTo        FlightLeg[]          @relation("FlightLegTo")

  @@index([continentCode])
  @@index([countryCode])
}

model AircraftCategory {
  id            Int             @id @default(autoincrement())
  code          String          @unique // LIGHT, MIDSIZE, HEAVY, etc.
  label         String
  maxPassengers Int             @default(8)
  
  models        AircraftModel[]
  fixedOptions  FixedPriceOption[]
}

model AircraftModel {
  id             Int              @id @default(autoincrement())
  manufacturer   String
  model          String
  categoryId     Int
  rangeKm        Int?
  speedKmh       Int?
  sleepCapacity  Int?
  cabinWidth     Decimal?         @db.Decimal(4, 2)
  cabinHeight    Decimal?         @db.Decimal(4, 2)
  cabinLength    Decimal?         @db.Decimal(4, 2)
  
  category       AircraftCategory @relation(fields: [categoryId], references: [id])
  quoteOffers    QuoteOffer[]
  emptyLegs      EmptyLegOffer[]
  fleet          Aircraft[]
}

/// Fleet tail / physical aircraft (CR Wave 1) — distinct from catalog AircraftModel
model Aircraft {
  id                   Int                      @id @default(autoincrement())
  registration         String                   @unique
  aircraftModelId      Int
  operatorId           Int?
  baseAirportId        Int
  currentAirportId     Int
  availableFrom        DateTime?
  availabilityStatus   String                   @default("AVAILABLE") // AVAILABLE ON_HOLD BOOKED IN_FLIGHT MAINTENANCE UNAVAILABLE INACTIVE
  hourlyRate           Decimal                  @db.Decimal(12, 2)
  hourlyRateCurrency   String                   @default("USD")
  minimumBillableHours Decimal                  @default(2) @db.Decimal(4, 1)
  locationUpdatedAt    DateTime                 @default(now())
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  aircraftModel        AircraftModel            @relation(fields: [aircraftModelId], references: [id])
  operator             Operator?                @relation(fields: [operatorId], references: [id])
  baseAirport          Airport                  @relation("AircraftBaseAirport", fields: [baseAirportId], references: [id])
  currentAirport       Airport                  @relation("AircraftCurrentAirport", fields: [currentAirportId], references: [id])
  locationHistory      AircraftLocationHistory[]
  flightLegs           FlightLeg[]
  bookingsSelected     Booking[]
  operatorContracts    OperatorContract[]

  @@index([currentAirportId, availabilityStatus])
  @@index([availabilityStatus])
}

model AircraftLocationHistory {
  id            Int       @id @default(autoincrement())
  aircraftId    Int
  fromAirportId Int?
  toAirportId   Int
  source        String    @default("MANUAL") // MANUAL FLIGHT_COMPLETE
  note          String?
  createdBy     Int?
  createdAt     DateTime  @default(now())

  aircraft      Aircraft  @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  fromAirport   Airport?  @relation("LocHistFrom", fields: [fromAirportId], references: [id])
  toAirport     Airport   @relation("LocHistTo", fields: [toAirportId], references: [id])

  @@index([aircraftId, createdAt])
}

/// Operational flight legs (positioning / passenger / …) — CR Wave 1–2
model FlightLeg {
  id                     Int           @id @default(autoincrement())
  bookingId              Int?
  quoteRequestId         Int?
  aircraftId             Int?
  fromAirportId          Int
  toAirportId            Int
  legType                String        // POSITIONING PASSENGER RETURN REPOSITIONING EMPTY_LEG
  departureAt            DateTime
  arrivalAt              DateTime?
  estimatedFlightMinutes Int
  distanceKm             Decimal?      @db.Decimal(10, 2)
  hasPassengers          Boolean       @default(false)
  passengerCount         Int           @default(0)
  hourlyRateApplied      Decimal?      @db.Decimal(12, 2)
  estimatedCost          Decimal?      @db.Decimal(12, 2)
  status                 String        @default("PLANNED") // PLANNED CONFIRMED COMPLETED CANCELLED
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  booking                Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  quoteRequest           QuoteRequest? @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  aircraft               Aircraft?     @relation(fields: [aircraftId], references: [id])
  fromAirport            Airport       @relation("FlightLegFrom", fields: [fromAirportId], references: [id])
  toAirport              Airport       @relation("FlightLegTo", fields: [toAirportId], references: [id])

  @@index([bookingId])
  @@index([quoteRequestId])
}

model Operator {
  id                Int          @id @default(autoincrement())
  name              String
  region            String
  complianceProfile Json?
  status            String       @default("ACTIVE")
  
  quoteOffers       QuoteOffer[]
  fleet             Aircraft[]
  contracts         OperatorContract[]
}

// --- CR Wave 3–5: contracts, DocuSign, RBAC ---

model ContractTemplate {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  bodyHtml  String
  version   Int      @default(1)
  status    String   @default("ACTIVE") // ACTIVE INACTIVE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts OperatorContract[]
}

model OperatorContract {
  id           Int       @id @default(autoincrement())
  aircraftId   Int
  operatorId   Int
  bookingId    Int?
  templateId   Int
  title        String
  bodyHtml     String
  status       String    @default("DRAFT") // DRAFT PENDING_APPROVAL APPROVED REJECTED SENT COMPLETED VOIDED
  version      Int       @default(1)
  createdBy    Int
  approvedBy   Int?
  approvedAt   DateTime?
  rejectedReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  aircraft     Aircraft         @relation(fields: [aircraftId], references: [id])
  operator     Operator         @relation(fields: [operatorId], references: [id])
  booking      Booking?         @relation(fields: [bookingId], references: [id])
  template     ContractTemplate @relation(fields: [templateId], references: [id])
  creator      User             @relation("ContractCreatedBy", fields: [createdBy], references: [id])
  approver     User?            @relation("ContractApprovedBy", fields: [approvedBy], references: [id])
  envelopes    DocuSignEnvelope[]

  @@index([aircraftId, status])
  @@index([status])
}

model DocuSignEnvelope {
  id                 Int       @id @default(autoincrement())
  operatorContractId Int
  externalEnvelopeId String    @unique
  status             String    @default("CREATED") // CREATED SENT DELIVERED COMPLETED DECLINED VOIDED
  recipients         Json?
  sentAt             DateTime?
  completedAt        DateTime?
  voidedAt           DateTime?
  certificateUrl     String?
  rawLastEvent       Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  operatorContract   OperatorContract @relation(fields: [operatorContractId], references: [id], onDelete: Cascade)

  @@index([operatorContractId])
}

model DocuSignWebhookEvent {
  id          Int       @id @default(autoincrement())
  eventId     String    @unique
  envelopeId  String
  eventType   String
  payload     Json
  processedAt DateTime  @default(now())

  @@index([envelopeId])
}

model UserPermissionOverride {
  id            Int      @id @default(autoincrement())
  userId        Int
  permissionKey String   // CANCEL_BOOKING CANCEL_QUOTE CANCEL_CONTRACT VOID_DOCUSIGN APPROVE_CONTRACT
  effect        String   // INHERIT ALLOW DENY
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionKey])
  @@index([userId])
}

model UserAirportScope {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  scopeType      String   @default("ALL") // ALL CONTINENT COUNTRY AIRPORT_LIST NONE
  continentCodes String[] @default([])
  countryCodes   String[] @default([])
  airportIds     Int[]    @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- COMMERCIAL PROGRAMS ---

model FixedPriceRoute {
  id            Int                @id @default(autoincrement())
  slug          String             @unique
  fromAirportId Int
  toAirportId   Int
  region        String
  status        String             @default("ACTIVE")
  createdAt     DateTime           @default(now())
  
  fromAirport   Airport            @relation("RouteFromAirport", fields: [fromAirportId], references: [id])
  toAirport     Airport            @relation("RouteToAirport", fields: [toAirportId], references: [id])
  options       FixedPriceOption[]
}

model FixedPriceOption {
  id            Int              @id @default(autoincrement())
  routeId       Int
  categoryId    Int
  price         Decimal          @db.Decimal(12, 2)
  paxLimit      Int              @default(8)
  includedTerms String?
  
  route         FixedPriceRoute  @relation(fields: [routeId], references: [id], onDelete: Cascade)
  category      AircraftCategory @relation(fields: [categoryId], references: [id])
}

model EmptyLegOffer {
  id              Int           @id @default(autoincrement())
  slug            String        @unique
  fromAirportId   Int
  toAirportId     Int
  departAt        DateTime
  aircraftModelId Int
  price           Decimal       @db.Decimal(12, 2)
  status          String        @default("ACTIVE") // ACTIVE, EXPIRED, BOOKED
  discountPct     Int           @default(0)
  createdAt       DateTime      @default(now())
  
  fromAirport     Airport       @relation("EmptyFromAirport", fields: [fromAirportId], references: [id])
  toAirport       Airport       @relation("EmptyToAirport", fields: [toAirportId], references: [id])
  aircraftModel   AircraftModel @relation(fields: [aircraftModelId], references: [id])
}

model JetCardPlan {
  id            Int              @id @default(autoincrement())
  name          String
  hours         Int
  validityYears Int              @default(2)
  minNoticeHours Int             @default(24)
  dailyMinHours Decimal          @db.Decimal(3, 1)
  price         Decimal          @db.Decimal(12, 2)
  
  accounts      JetCardAccount[]
}

model JetCardAccount {
  id             Int                  @id @default(autoincrement())
  userId         Int
  planId         Int
  purchasedAt    DateTime             @default(now())
  expiresAt      DateTime
  remainingHours Decimal              @db.Decimal(6, 2)
  
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           JetCardPlan          @relation(fields: [planId], references: [id])
  transactions   JetCardTransaction[]
}

model JetCardTransaction {
  id               Int            @id @default(autoincrement())
  jetCardAccountId Int
  txnType          String         // DEDUCTION, TOP_UP, FEE
  hoursDelta       Decimal        @db.Decimal(6, 2)
  bookingId        Int?
  note             String?
  createdAt        DateTime       @default(now())
  
  jetCardAccount   JetCardAccount @relation(fields: [jetCardAccountId], references: [id], onDelete: Cascade)
  booking          Booking?       @relation(fields: [bookingId], references: [id])
}

model TravelCreditPackage {
  id             Int      @id @default(autoincrement())
  name           String
  creditAmount   Decimal  @db.Decimal(12, 2)
  priceUsd       Decimal  @db.Decimal(12, 2)
  bonusPct       Decimal? @db.Decimal(5, 2)
  validityMonths Int      @default(12)
  currency       String   @default("USD")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TravelCreditLedger {
  id           Int      @id @default(autoincrement())
  userId       Int?
  companyId    Int?
  bookingId    Int?
  creditsDelta Decimal  @db.Decimal(12, 2)
  expiresAt    DateTime
  reason       String
  createdAt    DateTime @default(now())
  
  user         User?    @relation(fields: [userId], references: [id])
  company      Company? @relation(fields: [companyId], references: [id])
  booking      Booking? @relation(fields: [bookingId], references: [id])
}

// --- PARTNERS ---

model PartnerProgram {
  id           Int                  @id @default(autoincrement())
  code         String               @unique // SERVICE, REFERRAL, OFFICIAL
  name         String
  benefits     Json?
  
  applications PartnerApplication[]
  accounts     PartnerAccount[]
}

model PartnerApplication {
  id           Int            @id @default(autoincrement())
  userId       Int
  programId    Int
  whatsapp     String?
  wechat       String?
  reviewStatus String         @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedAt   DateTime?
  createdAt    DateTime       @default(now())
  
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  program      PartnerProgram @relation(fields: [programId], references: [id])
}

model PartnerAccount {
  id                   Int            @id @default(autoincrement())
  userId               Int
  companyId            Int?
  programId            Int
  dashboardPermissions String         @default("BASIC")
  createdAt            DateTime       @default(now())
  
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  company              Company?       @relation(fields: [companyId], references: [id])
  program              PartnerProgram @relation(fields: [programId], references: [id])
}

// --- CONTENT MANAGEMENT (CMS) ---

model ContentCategory {
  id       Int              @id @default(autoincrement())
  name     String
  slug     String           @unique
  articles ContentArticle[]
}

model ContentArticle {
  id           Int              @id @default(autoincrement())
  type         String           // NEWS, BLOG, LEGAL, PAGE
  slug         String           @unique
  categoryId   Int?
  author       String?
  thumbnail    String?
  isPublished  Boolean          @default(false)
  shareEnabled Boolean          @default(true)
  publishedAt  DateTime?
  createdAt    DateTime         @default(now())
  
  category     ContentCategory? @relation(fields: [categoryId], references: [id])
}

model ContentTranslation {
  id             Int     @id @default(autoincrement())
  entityType     String  // ARTICLE, VIDEO, PLAN, DESTINATION
  entityId       Int
  locale         String
  title          String
  body           String
  excerpt        String?
  seoTitle       String?
  seoDescription String?
  
  @@unique([entityType, entityId, locale])
}

model Video {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  videoUrl    String
  thumbnail   String?
  duration    Int       @default(0) // in seconds
  viewCount   Int       @default(0)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
}

model Destination {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  category    String    // ISLAND, SKI, GOLF
  city        String
  country     String
  thumbnail   String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --- CAMPAIGNS ---

model WorldCupMatch {
  id        Int        @id @default(autoincrement())
  matchDate DateTime
  stage     String
  homeTeam  String
  awayTeam  String
  hostCity  String
  stadium   String
  
  legs      QuoteLeg[]
}

model WorldCupItinerary {
  id             Int          @id @default(autoincrement())
  quoteRequestId Int          @unique
  campaignCode   String
  
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
}

// --- LOGS & MISC ---

model SavedSearch {
  id           Int      @id @default(autoincrement())
  userId       Int
  queryPayload Json
  locale       String   @default("en")
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConsentLog {
  id            Int      @id @default(autoincrement())
  userId        Int
  subject       String   // COOKIE_ANALYTICS, PRIVACY_POLICY, TERMS
  policyVersion String
  acceptedAt    DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  
  user      User?    @relation(fields: [userId], references: [id])
}

model OtpCode {
  id        Int       @id @default(autoincrement())
  phone     String
  code      String
  purpose   String    // LOGIN, REGISTER
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone, purpose])
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// --- CUSTOMER CARE EMAIL ---

model EmailSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  userId    Int?
  locale    String   @default("en")
  source    String   @default("NEWSLETTER")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

model EmailCampaignLog {
  id          Int       @id @default(autoincrement())
  email       String
  userId      Int?
  campaignKey String
  referenceId String    @default("")
  locale      String    @default("en")
  status      String    @default("PENDING")
  scheduledAt DateTime  @default(now())
  sentAt      DateTime?
  error       String?
  meta        Json?
  createdAt   DateTime  @default(now())

  @@unique([campaignKey, email, referenceId])
  @@index([status, scheduledAt])
  @@index([email])
}

{
  "name": "jetbay",
  "version": "1.0.0",
  "private": true,
  "description": "JETBAY Private Jet Booking Platform",
  "scripts": {
    "dev": "pnpm --filter \"*\" --parallel dev",
    "build": "pnpm --filter \"*\" build",
    "start": "pnpm --filter \"*\" start",
    "test": "pnpm --filter \"*\" test",
    "test:api": "pnpm --filter @jetbay/api test",
    "test:e2e": "playwright test",
    "audit:branding": "node scripts/audit-public-branding.mjs",
    "audit:debug": "node scripts/audit-debug.mjs",
    "generate:demo-placeholders": "node scripts/generate-demo-placeholders.mjs",
    "sync:jetvina-media": "node scripts/sync-jetvina-media.mjs",
    "manifest:jetvina-media": "node scripts/write-jetvina-manifest.mjs",
    "restart:web": "node scripts/restart-web-dev.mjs",
    "audit:asset-references": "node scripts/audit-asset-references.mjs",
    "validate:jetvina-media-manifest": "node scripts/validate-jetvina-media-manifest.mjs",
    "audit:docs": "node scripts/audit-docs.mjs",
    "import:jetvina-media": "node scripts/import-jetvina-media.mjs",
    "test:e2e:media-staging": "playwright test -c playwright.media-staging.config.ts",
    "test:e2e:media-production": "playwright test -c playwright.media-production.config.ts",
    "test:e2e:admin-media": "playwright test -c playwright.admin-media.config.ts",
    "test:media-permissions": "pnpm --filter @jetbay/api exec jest --testPathPatterns=media-permissions",
    "test:content-sync-publish": "pnpm --filter @jetbay/api exec jest --testPathPatterns=content-sync-publish",
    "test:content-sync-rollback": "pnpm --filter @jetbay/api exec jest --testPathPatterns=content-sync-rollback",
    "test:media-import-db": "pnpm --filter @jetbay/api exec jest --testPathPatterns=media-import",
    "lint": "pnpm --filter @jetbay/web exec eslint . --max-warnings=0 && pnpm --filter @jetbay/admin exec eslint . --max-warnings=0",
    "typecheck": "pnpm --filter @jetbay/web exec tsc --noEmit && pnpm --filter @jetbay/admin exec tsc --noEmit",
    "test:media": "npx tsx --test apps/web/src/lib/media-policy.test.ts apps/web/src/lib/resolve-media-asset.test.ts && node --test scripts/sync-jetvina-media-safety.test.mjs",
    "test:brand": "node scripts/audit-public-branding.mjs && pnpm --filter @jetbay/api exec jest --testPathPatterns=brand-public && cd apps/web && npx tsx --test src/lib/brand-assets.test.ts",
    "qa:ci": "pnpm --filter @jetbay/api prisma:generate && pnpm --filter @jetbay/api build && pnpm --filter @jetbay/api test && pnpm --filter @jetbay/admin build && pnpm --filter @jetbay/web build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "assets:jetbay": "node scripts/download-jetbay-assets.mjs",
    "rebrand:jetbay": "node scripts/rebrand-jetbay.mjs",
    "openapi:client": "node scripts/openapi/generate-client.mjs",
    "openapi:client:prod": "node scripts/openapi/generate-client.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "sharp"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "openapi-typescript-codegen": "^0.29.0",
    "pg": "^8.22.0",
    "typescript": "^5.0.0",
    "yaml": "^2.8.0"
  }
}

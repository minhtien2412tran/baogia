# Jet-Bay production — copy to /var/www/jetbay-be/.env (chmod 600)
# Prefer: bash deploy/rotate-secrets.sh  (generates openssl rand -hex, never prints)
# Or manually: openssl rand -hex 48
# NEVER copy secrets from /var/www/baotienweb-api/.env
# Docs: docs/SECURITY_SECRETS.md

# --- App (required by deploy spec) ---
APP_NAME=JetBay
APP_ENV=production
APP_VERSION=1.0.0
HOST=127.0.0.1
PORT=3010
APP_URL=https://api.minhtien.online
FRONTEND_URL=https://m-tien.com
NODE_ENV=production

# --- Database (Prisma reads DATABASE_URL) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=jetbay_db
DB_USERNAME=jetbay_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

DATABASE_URL=postgresql://jetbay_user:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/jetbay_db?schema=public

# --- Auth / API secrets (generate new values) ---
JWT_SECRET=CHANGE_ME_JWT_SECRET
REFRESH_TOKEN_SECRET=CHANGE_ME_REFRESH_SECRET
API_KEY=CHANGE_ME_API_KEY
PAYMENT_SECRET=CHANGE_ME_PAYMENT_SECRET

# --- Paths ---
UPLOAD_PATH=/var/www/jetbay-be/uploads
LOG_PATH=/var/www/jetbay-be/logs

# --- CORS / public URLs ---
CORS_ORIGIN=https://m-tien.com,https://www.m-tien.com,http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
API_PUBLIC_URL=https://api.minhtien.online
PAYMENT_RETURN_URL=https://m-tien.com/app-jetbay/account

# --- Redis (use separate DB index from other apps) ---
REDIS_URL=redis://127.0.0.1:6379/2

# --- Storage (local uploads fallback; MinIO optional) ---
MINIO_ENDPOINT=
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=jetbay-uploads

# --- Email (configure production SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM="JetBay <noreply@minhtien.online>"

# --- Payments (configure when going live) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ONEPAY_MERCHANT_ID=
ONEPAY_ACCESS_CODE=
ONEPAY_SECURE_SECRET=
NINEPAY_MERCHANT_KEY=
NINEPAY_SECRET_KEY=

# --- OAuth (optional) ---
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
